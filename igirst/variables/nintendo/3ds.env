# This ENV file uses defaults based on my needs for US+WORLD 1G1R with Exclusions for a set that only contains retail games sold during the systems lifespan in stores
# Configure everything to suit your own needs, I have left these settings in simply as an example



# DAT File - **This MUST be set**
# Absolute or relative path from IGIRST.SH as well as wildcards in the DAT filename work. If using a wildcard, ensure only 1 DAT exists for the system
dat="./dats/nintendo/Nintendo - Nintendo 3DS (Decrypted) (Parent-Clone)*.*"

# Input ROMs Directory - **This MUST be set**
# Absolute or relative path from IGIRST.SH
input="../Nintendo/3DS/Roms"

# Output ROMs Directory - **This MUST be set**
# Absolute or relative path from IGIRST.SH, or the input variable
output="$input"

# Backup for cleanup - **This MUST be set**
# You don't have to keep backups and can select otherwise, but a check is done for this or IGIR will error if selecting a command with backups
# The directory doesn't have to exist, and will not be created if not using a command with backups
backup="$output/../backup"

# Regions - At least one region must be specified here, in order of preference
regions="USA,WORLD"

# Excludes in Glob format - Can be empty
exclude="(Ace Combat - Assault Horizon Legacy \(USA\)|Disney 2-Pack - Frozen - Olaf's Quest \+ Big Hero 6 - Battle in the Bay|Pokemon Moon|Pokemon Sun|Teenage Mutant Ninja Turtles - Master Splinter's Training Pack)"

# ROM Options - Can be empty, set whatever IGIR options you want to use here
options="--single --no-bios --only-retail --no-unlicensed --prefer-revision newer"

#Report Filename - **This MUST be set**
# Absolute or relative path from IGIRST.SH, or the output variable
report="$output/../Nintendo - Nintendo 3DS (Decrypted) (Parent-Clone).csv"
